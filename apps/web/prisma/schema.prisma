generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  INSTRUCTOR
  TA
}

enum CourseRole {
  INSTRUCTOR
  TA
}

enum Semester {
  SPRING
  SUMMER
  FALL
}

enum SessionCategory {
  GRADING
  OFFICE_HOURS
  LAB_PREP
  TUTORING
  MEETINGS
  OTHER
}

enum SessionMode {
  SCREEN
  IN_PERSON
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum EventType {
  STARTED
  PAUSED
  RESUMED
  STOPPED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum AuditAction {
  SESSION_STARTED
  SESSION_PAUSED
  SESSION_RESUMED
  SESSION_STOPPED
  SUBMITTED
  APPROVED
  REJECTED
  EXPORTED
  SETTINGS_CHANGED
  USER_INVITED
  PROOF_PURGED
  BUDGET_CHANGED
  DISPUTE_HOLD_TOGGLED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  courseAssignments       CourseAssignment[]
  reviewedSubmissions     WeeklySubmission[]  @relation("reviewer")
  auditLogs               AuditLog[]
  systemSettingsUpdated   SystemSettings[]    @relation("updatedBy")

  @@map("users")
}

model Course {
  id                   String   @id @default(uuid())
  name                 String
  code                 String
  semester             Semester
  year                 Int
  enrolledStudents     Int      @map("enrolled_students")
  hoursPerStudent      Decimal  @default(0.15) @map("hours_per_student") @db.Decimal(5, 2)
  overrideWeeklyBudget Decimal? @map("override_weekly_budget") @db.Decimal(6, 2)
  createdAt            DateTime @default(now()) @map("created_at")

  assignments CourseAssignment[]

  @@map("courses")
}

model CourseAssignment {
  id             String     @id @default(uuid())
  userId         String     @map("user_id")
  courseId       String     @map("course_id")
  role           CourseRole
  maxWeeklyHours Decimal?   @map("max_weekly_hours") @db.Decimal(5, 2)
  createdAt      DateTime   @default(now()) @map("created_at")

  user        User               @relation(fields: [userId], references: [id])
  course      Course             @relation(fields: [courseId], references: [id])
  sessions    WorkSession[]
  submissions WeeklySubmission[]

  @@unique([userId, courseId])
  @@map("course_assignments")
}

model WorkSession {
  id            String          @id @default(uuid())
  assignmentId  String          @map("assignment_id")
  submissionId  String?         @map("submission_id")
  category      SessionCategory
  mode          SessionMode
  description   String?         @db.Text
  startedAt     DateTime        @map("started_at")
  endedAt       DateTime?       @map("ended_at")
  activeMinutes Int             @default(0) @map("active_minutes")
  idleMinutes   Int             @default(0) @map("idle_minutes")
  netHours      Decimal         @default(0) @map("net_hours") @db.Decimal(6, 2)
  status        SessionStatus   @default(ACTIVE)
  createdAt     DateTime        @default(now()) @map("created_at")

  assignment  CourseAssignment  @relation(fields: [assignmentId], references: [id])
  submission  WeeklySubmission? @relation(fields: [submissionId], references: [id])
  events      SessionEvent[]
  screenshots Screenshot[]
  photos      PhotoProof[]

  @@map("work_sessions")
}

/// Append-only event log — server-authoritative timing for anti-fraud
model SessionEvent {
  id              String    @id @default(uuid())
  sessionId       String    @map("session_id")
  eventType       EventType @map("event_type")
  serverTimestamp DateTime  @map("server_timestamp")
  clientTimestamp DateTime? @map("client_timestamp")
  createdAt       DateTime  @default(now()) @map("created_at")

  session WorkSession @relation(fields: [sessionId], references: [id])

  @@map("session_events")
}

model Screenshot {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  capturedAt   DateTime @map("captured_at")
  fileUrl      String   @map("file_url")
  thumbnailUrl String   @map("thumbnail_url")
  fileSize     Int      @map("file_size")
  minuteMark   Int      @map("minute_mark")
  createdAt    DateTime @default(now()) @map("created_at")

  session WorkSession @relation(fields: [sessionId], references: [id])

  @@map("screenshots")
}

model PhotoProof {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  fileSize   Int      @map("file_size")
  caption    String   @db.Text
  uploadedAt DateTime @map("uploaded_at")

  session WorkSession @relation(fields: [sessionId], references: [id])

  @@map("photo_proofs")
}

model WeeklySubmission {
  id               String           @id @default(uuid())
  assignmentId     String           @map("assignment_id")
  weekStart        DateTime         @map("week_start") @db.Date
  weekEnd          DateTime         @map("week_end") @db.Date
  totalHours       Decimal          @default(0) @map("total_hours") @db.Decimal(6, 2)
  totalScreenshots Int              @default(0) @map("total_screenshots")
  status           SubmissionStatus @default(DRAFT)
  reviewerId       String?          @map("reviewer_id")
  rejectionReason  String?          @map("rejection_reason") @db.Text
  submittedAt      DateTime?        @map("submitted_at")
  reviewedAt       DateTime?        @map("reviewed_at")
  exported         Boolean          @default(false)
  exportedAt       DateTime?        @map("exported_at")
  disputeHold      Boolean          @default(false) @map("dispute_hold")

  assignment CourseAssignment @relation(fields: [assignmentId], references: [id])
  reviewer   User?            @relation("reviewer", fields: [reviewerId], references: [id])
  sessions   WorkSession[]

  @@unique([assignmentId, weekStart])
  @@map("weekly_submissions")
}

/// Key-value store for system-wide configuration and ephemeral tokens (invites, refresh tokens)
model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedBy String   @map("updated_by")
  updatedAt DateTime @map("updated_at")

  updatedByUser User @relation("updatedBy", fields: [updatedBy], references: [id])

  @@map("system_settings")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  details    Json?
  ipAddress  String?     @map("ip_address")
  createdAt  DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
